// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ActualOutput {
  id           String   @id @db.Uuid
  hourSlot     String?  @map("hour_slot")
  output       String?
  targetOutput Decimal? @default(1000) @map("target_output") @db.Decimal
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  dataItemId   String?  @map("data_item_id") @db.Uuid

  dataItem DataItem? @relation(fields: [dataItemId], references: [id])

  @@map("actual_output")
}

model DataItem {
  id             String    @id @db.Uuid
  sn             String    @db.Uuid
  status         String?
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  lineProcessId  String?   @map("line_process_id") @db.Uuid

  snRelation     Sn?           @relation(fields: [sn], references: [id])
  lineProcess    LineProcess?  @relation(fields: [lineProcessId], references: [id])
  actualOutputs  ActualOutput[]

  @@map("data_items")
}

model Line {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String?
  status            String?
  totalRunningHours Decimal?  @map("total_running_hours") @db.Decimal
  lastActiveAt      DateTime? @map("last_active_at") @db.Timestamptz(6)

  lineProcesses LineProcess[]
  workOrders    WorkOrder[]
  partNumbers   Pn[]
  oeeSummaries  OeeSummary[]

  @@map("line")
}

model LineProcess {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lineId       String    @map("line_id") @db.Uuid
  processId    String    @map("process_id") @db.Uuid
  processOrder Int?      @map("process_order")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  line      Line       @relation(fields: [lineId], references: [id])
  process   Process    @relation(fields: [processId], references: [id])
  dataItems DataItem[]

  @@map("line_process")
}

model Machine {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nameMachine       String?   @map("name_machine")
  status            String?
  nextMaintenance   DateTime? @map("next_maintenance") @db.Timestamp(6)
  lastMaintenance   DateTime? @map("last_maintenance") @db.Timestamp(6)
  totalRunningHours String?   @map("total_running_hours")
  totalDowntimeHours String?   @map("total_downtime_hours")

  processes      Process[]
  notifications  Notification[]
  workOrders     WorkOrder[]
  statusLogs     MachineStatusLog[]
  oeeSummaries   OeeSummary[]

  @@map("machine")
}

model MachineStatusLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  machineId       String    @map("machine_id") @db.Uuid
  status          String
  startTime       DateTime  @default(now()) @map("start_time") @db.Timestamptz(6)
  endTime         DateTime? @map("end_time") @db.Timestamptz(6)
  durationSeconds BigInt?   @map("duration_seconds")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId], name: "idx_msl_machine_open")
  @@map("machine_status_log")
}

model Note {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId String?   @default(dbgenerated("gen_random_uuid()")) @map("work_order_id") @db.Uuid
  text        String?
  author      String?
  timestamp   DateTime? @db.Timestamp(6)

  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@map("note")
}

model Notification {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type           String?
  severity       String?
  machineId      String?   @default(dbgenerated("gen_random_uuid()")) @map("machine_id") @db.Uuid
  machineName    String?   @map("machine_name")
  messages       String?
  read           String?
  acknowladged   String?
  acknowladgedBy String?   @map("acknowladged_by")
  acknowladgedAt DateTime? @map("acknowladged_at") @db.Timestamp(6)
  duration       String?
  startAt        DateTime? @map("start_at") @db.Timestamp(6)
  doneAt         DateTime? @map("done_at") @db.Timestamp(6)
  processId      String?   @map("process_id") @db.Uuid
  workOrderId    String?   @map("work_order_id") @db.Uuid

  machine   Machine?   @relation(fields: [machineId], references: [id])
  process   Process?   @relation(fields: [processId], references: [id])
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@map("notification")
}

model Pn {
  id         String   @id @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  partNumber String?  @map("part_number") @db.VarChar
  lineId     String?  @map("line_id") @db.Uuid

  line          Line?  @relation(fields: [lineId], references: [id])
  serialNumbers Sn[]

  @@map("pn")
}

model Process {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String?
  index     Decimal? @db.Decimal
  machineId String?  @map("machine_id") @db.Uuid

  machine       Machine?       @relation(fields: [machineId], references: [id])
  lineProcesses LineProcess[]
  notifications Notification[]

  @@map("process")
}

model Shift {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftName String   @map("shift_name") @db.VarChar
  startTime DateTime @map("start_time") @db.Time(6)
  endTime   DateTime @map("end_time") @db.Time(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  oeeSummaries OeeSummary[]

  @@map("shift")
}

model Sn {
  id            String   @id @db.Uuid
  partNumberId  String?  @map("part_number_id") @db.Uuid
  serialNumber  String?  @map("serial_number") @db.VarChar
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  partNumber Pn?        @relation(fields: [partNumberId], references: [id])
  dataItems  DataItem[]

  @@map("sn")
}

model Task {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workOrderId String? @default(dbgenerated("gen_random_uuid()")) @map("work_order_id") @db.Uuid
  description String?
  completed   String?
  completedAt String? @map("completed_at")

  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@map("task")
}

model Technician {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String?
  specialization String?
  contactInfo    String?  @map("contact_info")
  isActive       Boolean? @map("is_active")

  @@map("technician")
}

model WorkOrder {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type              String?
  priority          String?
  machineId         String?   @default(dbgenerated("gen_random_uuid()")) @map("machine_id") @db.Uuid
  machineName       String?   @map("machine_name")
  lineId            String?   @default(dbgenerated("gen_random_uuid()")) @map("line_id") @db.Uuid
  nameLine          String?   @map("name_line")
  status            String?
  assignedTo        String?   @map("assigned_to")
  createdAt         DateTime? @map("created_at") @db.Timestamp(6)
  scheduleDate      DateTime? @map("schedule_date") @db.Timestamp(6)
  completedAt       DateTime? @map("completed_at") @db.Timestamp(6)
  estimatedDuration String?   @map("estimated_duration")
  actualDuration    String?   @map("actual_duration")
  description       String?
  workOrderCode     String?   @map("work_order_code")

  machine       Machine?       @relation(fields: [machineId], references: [id])
  line          Line?          @relation(fields: [lineId], references: [id])
  notes         Note[]
  tasks         Task[]
  notifications Notification[]

  @@map("work_order")
}

model OeeSummary {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date                 DateTime @db.Date
  shiftId              String?  @map("shift_id") @db.Uuid
  lineId               String   @map("line_id") @db.Uuid
  machineId            String   @map("machine_id") @db.Uuid

  plannedTimeSeconds   BigInt?  @map("planned_time_seconds")
  operatingTimeSeconds BigInt?  @map("operating_time_seconds")
  downtimeSeconds      BigInt?  @map("downtime_seconds")

  totalOutput          BigInt?  @map("total_output")
  goodOutput           BigInt?  @map("good_output")
  rejectOutput         BigInt?  @map("reject_output")

  availability         Decimal? @db.Decimal(6, 4)
  performance          Decimal? @db.Decimal(6, 4)
  quality              Decimal? @db.Decimal(6, 4)
  oee                  Decimal? @db.Decimal(6, 4)

  createdAt            DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  machine              Machine   @relation(fields: [machineId], references: [id])
  line                 Line      @relation(fields: [lineId], references: [id])
  shift                Shift?    @relation(fields: [shiftId], references: [id])

  @@map("oee_summary")
}
