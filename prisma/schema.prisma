  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  line_id         String      @db.Uuid
  line_process_id String      @db.Uuid
  shift_id        String?     @db.Uuid
  recorded_date   DateTime    @default(dbgenerated("CURRENT_DATE")) @db.Date
  recorded_hour   Int?
  total_produced  BigInt      @default(0)
  total_pass      BigInt      @default(0)
  total_reject    BigInt      @default(0)
